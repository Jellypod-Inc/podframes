{
  "name": "@podframes/core",
  "version": "0.1.0",
  "description": "The podframes pipeline engine: topic → Speechbase conversation → Gemini stills/video → HyperFrames render.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./shared": {
      "types": "./src/shared.ts",
      "default": "./src/shared.ts"
    },
    "./timeline": {
      "types": "./src/compose/trim.ts",
      "default": "./src/compose/trim.ts"
    },
    "./package.json": "./package.json"
  },
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Jellypod-Inc/podframes"
  },
  "homepage": "https://github.com/Jellypod-Inc/podframes",
  "bugs": "https://github.com/Jellypod-Inc/podframes/issues",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/compose/builder.test.ts src/stages/turn-timing.test.ts src/stages/stills.test.ts src/project.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@fal-ai/client": "^1.10.0",
    "@google/genai": "^2.8.0",
    "@speech-sdk/core": "^0.16.0",
    "dotenv": "^16.4.7",
    "hyperframes": "^0.6.110",
    "replicate": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
