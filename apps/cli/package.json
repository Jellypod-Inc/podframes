{
  "name": "podframes-cli",
  "version": "0.1.0",
  "description": "Command-line runner for the podframes pipeline.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jellypod-Inc/podframes"
  },
  "homepage": "https://github.com/Jellypod-Inc/podframes",
  "bugs": "https://github.com/Jellypod-Inc/podframes/issues",
  "type": "module",
  "bin": {
    "podframes": "dist/index.js"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --target node22 --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@podframes/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
